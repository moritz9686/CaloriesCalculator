PORT=4000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/calories-calculator
JWT_SECRET=replace-this-with-a-long-secret

# Optional: enables real AI food analysis. Without it, /food/analyze returns a
# deterministic fallback estimate so the flow still works end to end.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
